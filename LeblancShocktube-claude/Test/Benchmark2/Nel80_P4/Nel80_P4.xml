<?xml version='1.0' encoding='utf-8'?>
<NEKTAR>
	<EXPANSIONS>
		<E COMPOSITE="C[0]" NUMMODES="5" FIELDS="rho,rhou,E" TYPE="GLL_LAGRANGE" />
	</EXPANSIONS>
	<CONDITIONS>
		<PARAMETERS>
			<P> TimeStep = 0.0005555555555555556 </P>
			<P> FinTime = 3.0 </P>
			<P> NumSteps = 5400 </P>
			<P> IO_CheckSteps = 900 </P>
			<P> IO_InfoSteps = 900 </P>
			<P> IO_CFLSteps = 900 </P>
			<P> Gamma          = 5.0/3.0                             </P>
			<P> rhoL           = 1.0                                 </P>
			<P> rhoR           = 1.0e-3                              </P>
			<P> uL             = 0.0                                 </P>
			<P> uR             = 0.0                                 </P>
			<P> pL             = (Gamma - 1) * 0.1                   </P>
			<P> pR             = (Gamma - 1) * 1e-10                 </P>
			<P> EL             = pL/(Gamma - 1.0) + 0.5*rhoL*(uL*uL) </P>
			<P> ER             = pR/(Gamma - 1.0) + 0.5*rhoR*(uR*uR) </P>
			<P> Skappa = -1.3 </P>
			<P> Kappa = 0.2 </P>
			<P> mu0 = 1 </P>
		</PARAMETERS>
		<SOLVERINFO>
			<I PROPERTY="EQTYPE" VALUE="EulerCFE" />
			<I PROPERTY="Projection" VALUE="DisContinuous" />
			<I PROPERTY="AdvectionType" VALUE="WeakDG" />
			<I PROPERTY="UpwindType" VALUE="LaxFriedrichs" />
			<I PROPERTY="ProblemType" VALUE="General" />
			<I PROPERTY="ShockCaptureType" VALUE="NonSmooth" />
		</SOLVERINFO>
		<TIMEINTEGRATIONSCHEME>
			<METHOD> RungeKutta </METHOD>
			<ORDER> 2 </ORDER>
			<VARIANT> SSP </VARIANT>
		</TIMEINTEGRATIONSCHEME>
		<VARIABLES>
			<V ID="0"> rho </V>
			<V ID="1"> rhou </V>
			<V ID="2"> E </V>
		</VARIABLES>
		<BOUNDARYREGIONS>
			<B ID="0"> C[1] </B>
			<B ID="1"> C[2] </B>
		</BOUNDARYREGIONS>
		<BOUNDARYCONDITIONS>
			<REGION REF="0">
				<D VAR="rho" VALUE="rhoL" />
				<D VAR="rhou" VALUE="rhoL*uL" />
				<D VAR="E" VALUE="EL" />
			</REGION>
			<REGION REF="1">
				<D VAR="rho" VALUE="rhoR" />
				<D VAR="rhou" VALUE="rhoR*uR" />
				<D VAR="E" VALUE="ER" />
			</REGION>
		</BOUNDARYCONDITIONS>
		<FUNCTION NAME="InitialConditions">
			<E VAR="rho" DOMAIN="0" VALUE="rhoL + 0.5*(1+tanh((x-3)/0.5)) * (rhoR-rhoL)" />
			<E VAR="rhou" DOMAIN="0" VALUE="0" />
			<E VAR="E" DOMAIN="0" VALUE="EL + 0.5*(1+tanh((x-3)/0.5)) * (ER-EL)" />
		</FUNCTION>
	</CONDITIONS>
