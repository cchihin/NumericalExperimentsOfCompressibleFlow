			<V ID="4">-0.6667 0.0000 0.0000</V>
			<V ID="5">-0.5833 0.0000 0.0000</V>
			<V ID="6">-0.5000 0.0000 0.0000</V>
			<V ID="7">-0.4167 0.0000 0.0000</V>
			<V ID="8">-0.3333 0.0000 0.0000</V>
			<V ID="9">-0.2500 0.0000 0.0000</V>
			<V ID="10">-0.1667 0.0000 0.0000</V>
			<V ID="11">-0.0833 0.0000 0.0000</V>
			<V ID="12">0.0000 0.0000 0.0000</V>
			<V ID="13">0.0833 0.0000 0.0000</V>
			<V ID="14">0.1667 0.0000 0.0000</V>
			<V ID="15">0.2500 0.0000 0.0000</V>
			<V ID="16">0.3333 0.0000 0.0000</V>
			<V ID="17">0.4167 0.0000 0.0000</V>
			<V ID="18">0.5000 0.0000 0.0000</V>
			<V ID="19">0.5833 0.0000 0.0000</V>
			<V ID="20">0.6667 0.0000 0.0000</V>
			<V ID="21">0.7500 0.0000 0.0000</V>
			<V ID="22">0.8333 0.0000 0.0000</V>
			<V ID="23">0.9167 0.0000 0.0000</V>
			<V ID="24">1.0000 0.0000 0.0000</V>
		</VERTEX>
		<ELEMENT>
			<S ID="0">       0        1</S>
			<S ID="1">       1        2</S>
			<S ID="2">       2        3</S>
